{
  "name": "@veratools/fraud-sdk-expo",
  "version": "0.1.0",
  "description": "React Native / Expo behavioral-fraud SDK — touch & keystroke dynamics, device fingerprint, screen-share / remote-access detection, session risk. Emits the same mobile wire as the Android SDK; posts to the collector with a public site key.",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app.plugin.js": "./app.plugin.js"
  },
  "files": [
    "dist",
    "android",
    "expo-module.config.json",
    "app.plugin.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.check.json"
  },
  "peerDependencies": {
    "react": "*",
    "react-native": "*",
    "expo": ">=50"
  },
  "dependencies": {
    "expo-crypto": "*",
    "expo-device": "*",
    "expo-secure-store": "*"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "UNLICENSED"
}
